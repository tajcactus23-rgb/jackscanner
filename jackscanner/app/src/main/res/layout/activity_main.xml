<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_primary"
    android:gravity="center_horizontal">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.15"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.1"
        android:layout_marginTop="4dp" />

    <!-- Status Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_label"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:textAllCaps="true"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ready_status"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/status_idle"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="80dp"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/deviceCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/devices_found"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Scan Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="@string/start_scan"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/accent_primary" />

    <!-- Settings Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettings"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="@string/settings"
        android:textSize="14sp"
        android:textColor="@color/text_tertiary" />

    <!-- Footer Info -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:gravity="center">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_ble"
            app:tint="@color/text_tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/target_oui"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>